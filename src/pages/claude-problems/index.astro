<script>
const controls = Array.from(document.querySelectorAll<HTMLElement>("[data-problem]"));
const panels = Array.from(document.querySelectorAll<HTMLElement>("[data-panel]"));
const scenario = document.getElementById("scenario");

function setProblem(id: string, shouldScroll = true) {
  controls.forEach((control) => {
    const active = control.dataset.problem === id;
    control.classList.toggle("is-active", active);
    control.setAttribute("aria-pressed", String(active));
  });

  panels.forEach((panel) => {
    panel.hidden = panel.dataset.panel !== id;
  });

  if (history.replaceState) {
    history.replaceState(null, "", `#${id}`);
  }

  if (shouldScroll && scenario) {
    scenario.scrollIntoView({ block: "start", behavior: "smooth" });
  }
}

controls.forEach((control) => {
  control.addEventListener("click", () => {
    const problem = control.dataset.problem;
    if (problem) setProblem(problem);
  });
});

const initial = window.location.hash.replace("#", "");
if (["growth", "partners", "fork", "alone"].includes(initial)) {
  setProblem(initial, false);
}
</script>
