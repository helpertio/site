<style>
:root{
  --ink:        #0a0908;
  --ink-2:      #15120e;
  --paper:      #ecdcc2;
  --paper-dim:  #9a8f7c;
  --paper-mute: #6b6253;
  --rule:       rgba(236, 220, 194, 0.16);
  --rule-strong:rgba(236, 220, 194, 0.42);
  --gold:       #c8a45e;
  --serif: "EB Garamond", "Source Serif Pro", Georgia, serif;
  --sans:  "Inter", -apple-system, BlinkMacSystemFont, sans-serif;
  --mono:  "JetBrains Mono", ui-monospace, "SF Mono", Menlo, monospace;
}
*,*::before,*::after{box-sizing:border-box}
html,body{margin:0;padding:0}
html{-webkit-text-size-adjust:100%;scroll-behavior:smooth}
body{
  background: var(--ink);
  color: var(--paper);
  font-family: var(--sans);
  font-size: 17px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  text-rendering: optimizeLegibility;
}
img{display:block;max-width:100%;height:auto}
a{color:inherit;text-decoration:none}
h1,h2,h3,h4,p,ul,ol,figure,blockquote{margin:0;padding:0}
ul,ol{list-style:none}
::selection{background:var(--gold);color:var(--ink)}

.page{
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 clamp(20px, 4vw, 56px);
}

/* ── Topbar ──────────────────────────────────── */
.topbar{
  min-height: 72px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  border-bottom: 1px solid var(--rule);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--paper-dim);
}
.topbar__brand{ color: var(--paper); }
.topbar__brand em{
  font-family: var(--serif);
  font-style: italic;
  font-size: 14px;
  letter-spacing: 0;
  text-transform: none;
  color: var(--gold);
  margin-left: 10px;
}
.topbar__nav{
  display: flex;
  gap: 16px;
  align-items: center;
}
.topbar__nav a{
  border-bottom: 1px solid transparent;
  padding-bottom: 3px;
  font-size: 10px;
  letter-spacing: .1em;
  transition: border-color .18s, color .18s;
}
.topbar__nav a:hover{
  color: var(--gold);
  border-color: var(--gold);
}
.topbar__nav a:last-child{
  color: var(--paper);
  border-bottom: 1px solid var(--rule-strong);
}
.topbar__nav a:last-child:hover{
  color: var(--gold);
  border-color: var(--gold);
}

/* ── Slim reveal nav ─────────────────────────── */
.slimnav{
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 60;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  height: 58px;
  padding: 0 clamp(20px, 4vw, 56px);
  background: rgba(10, 9, 8, 0.82);
  -webkit-backdrop-filter: blur(12px);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--rule);
  transform: translateY(-100%);
  transition: transform .32s ease;
  will-change: transform;
}
.slimnav.is-visible{ transform: translateY(0); }
.slimnav__brand{
  font-family: var(--serif);
  font-style: italic;
  font-size: 16px;
  color: var(--paper);
}
.slimnav__nav{ display: flex; gap: 18px; align-items: center; }
.slimnav__nav a{
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--paper-dim);
  border-bottom: 1px solid transparent;
  padding-bottom: 3px;
  transition: color .18s, border-color .18s;
}
.slimnav__nav a:hover{ color: var(--gold); border-color: var(--gold); }
.slimnav__cta{
  color: var(--paper) !important;
  border-bottom: 1px solid var(--rule-strong) !important;
}
.slimnav__cta:hover{ color: var(--gold) !important; border-color: var(--gold) !important; }
@media (max-width: 800px){
  .slimnav__nav a:not(.slimnav__cta){ display: none; }
}

/* ── Hero ────────────────────────────────────── */
.hero{
  display: grid;
  grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr);
  gap: clamp(40px, 6vw, 100px);
  align-items: center;
  padding: clamp(32px, 4vw, 52px) 0 clamp(28px, 3vw, 44px);
  border-bottom: 1px solid var(--rule);
}
.hero__eyebrow{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--paper-mute);
  margin-bottom: 32px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.hero__headline{
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(2.2rem, 5.2vw, 4.2rem);
  line-height: 1.05;
  letter-spacing: -0.015em;
  color: var(--paper);
  margin-bottom: clamp(24px, 3vw, 36px);
}
.hero__headline em{
  font-style: italic;
  color: var(--gold);
}
.hero__answer{
  font-family: var(--serif);
  font-size: clamp(1.5rem, 2.8vw, 2.2rem);
  line-height: 1.2;
  color: var(--paper);
  margin-bottom: clamp(24px, 3vw, 36px);
}
.hero__deck{
  font-family: var(--serif);
  font-size: clamp(1.05rem, 1.4vw, 1.22rem);
  line-height: 1.5;
  color: var(--paper-dim);
  max-width: 44ch;
  margin-bottom: clamp(28px, 3vw, 40px);
}
.hero__answer{
  font-family: var(--serif);
  font-size: clamp(1.5rem, 2.8vw, 2.2rem);
  line-height: 1.2;
  color: var(--paper);
  margin-bottom: clamp(24px, 3vw, 36px);
}
.hero__deck{
  font-family: var(--serif);
  font-size: clamp(1.05rem, 1.4vw, 1.22rem);
  line-height: 1.5;
  color: var(--paper-dim);
  max-width: 44ch;
  margin-bottom: clamp(28px, 3.5vw, 44px);
}
.hero__byline{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--paper-dim);
  padding-top: 18px;
  border-top: 1px solid var(--rule);
  line-height: 1.6;
}
.hero__actions{
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 28px;
}
.btn{
  min-height: 52px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 28px;
  border: 1px solid var(--paper);
  background: var(--paper);
  color: var(--ink);
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  text-align: center;
  transition: all .18s;
}
.btn:hover{ background: var(--gold); border-color: var(--gold); }
.btn--ghost{
  background: transparent;
  color: var(--paper);
  border-color: var(--rule-strong);
}
.btn--ghost:hover{ background: var(--paper); color: var(--ink); }

.hero__photo img{
  width: 100%;
  height: min(68svh, 580px);
  object-fit: cover;
  object-position: center 15%;
  border: 1px solid var(--rule-strong);
  filter: grayscale(0.2) contrast(1.05) brightness(0.92);
}

/* ── Section frame ───────────────────────────── */
.section{
  padding: clamp(80px, 10vw, 140px) 0;
  border-bottom: 1px solid var(--rule);
}
.section__head{
  display: grid;
  grid-template-columns: minmax(140px, .38fr) minmax(0, 1fr);
  gap: clamp(24px, 5vw, 80px);
  align-items: start;
  margin-bottom: clamp(48px, 6vw, 80px);
}
.section__mark{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--paper-mute);
}
.section__mark em{
  display: block;
  margin-bottom: 10px;
  font-family: var(--serif);
  font-style: italic;
  font-size: 20px;
  letter-spacing: 0;
  text-transform: none;
  color: var(--gold);
}
.section__title{
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(1.9rem, 3.6vw, 3rem);
  line-height: 1.1;
  letter-spacing: -0.01em;
  color: var(--paper);
}
.section__title em{
  font-style: italic;
  color: var(--gold);
}

/* ── Position (pullquote) ────────────────────── */
.position{
  font-family: var(--serif);
  font-size: clamp(1.8rem, 3.4vw, 2.8rem);
  font-weight: 400;
  line-height: 1.25;
  color: var(--paper);
  letter-spacing: -0.005em;
  max-width: 28ch;
  margin: 0 auto;
  text-align: center;
  padding: 0 clamp(0px, 4vw, 60px);
}
.position em{
  font-style: italic;
  color: var(--gold);
}
.position__sig{
  display: block;
  margin-top: 36px;
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--paper-mute);
}

/* ── Footer ──────────────────────────────────── */
.foot{
  padding: 36px 0 56px;
  display: flex;
  justify-content: space-between;
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--paper-mute);
  border-top: 1px solid var(--rule);
  flex-wrap: wrap;
  gap: 12px;
}

/* ── Responsive ──────────────────────────────── */
@media (max-width: 800px){
  .topbar__nav a:not(:last-child){ display: none; }
  .topbar__brand em{ display: none; }
  .hero{
    grid-template-columns: 1fr;
    gap: 50px;
    padding-top: 50px; padding-bottom: 50px;
  }
  .hero__photo{ order: -1; max-width: 360px; }
  .section__head{ grid-template-columns: 1fr; gap: 16px; }
  .foot{ flex-direction: column; }
}

@media (prefers-reduced-motion: reduce){
  html{scroll-behavior:auto}
  *{animation:none !important;transition:none !important}
}






/* ── Proof v2 — Timeline ───────────────────── */
.proof-v2__header{ margin-bottom: 56px; }
.proof-v2__title{
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(28px, 4vw, 48px);
  line-height: 1.1;
  color: var(--paper);
  margin: 16px 0 0;
  max-width: 22ch;
}
.proof-v2__title em{
  font-style: italic;
  color: var(--gold);
}
.proof-v2__grid{
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 64px;
  align-items: start;
}
.proof-v2__photo{
  position: sticky;
  top: 80px;
}
.proof-v2__photo img{
  width: 100%;
  border-radius: 2px;
  filter: grayscale(.15);
}
.proof-v2__timeline{
  display: grid;
  gap: 0;
}
.tl-item{
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 48px;
  padding: 40px 0;
  border-top: 1px solid var(--rule);
  align-items: baseline;
}
.tl-item:last-child{ border-bottom: 1px solid var(--rule); }
.tl-item__marker{ display: flex; gap: 16px; align-items: baseline; }
.tl-item__num{
  font-family: var(--mono);
  font-size: 13px;
  letter-spacing: .16em;
  color: var(--gold);
}
.tl-item__label{
  font-family: var(--serif);
  font-weight: 500;
  font-size: clamp(20px, 2.2vw, 26px);
  line-height: 1.2;
  color: var(--paper);
}
.tl-item__text{
  font-family: var(--serif);
  font-size: 18px;
  line-height: 1.6;
  color: var(--paper-dim);
  margin: 0;
  max-width: 58ch;
}
.proof-v2__coda{
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(22px, 3vw, 30px);
  line-height: 1.3;
  color: var(--gold);
  margin: 80px 0 0;
  max-width: 30ch;
}

@media(max-width:980px){
  .proof-v2__grid{ grid-template-columns:1fr; }
  .proof-v2__photo{ position:static; max-width:400px; margin-bottom:40px; order:-1; }
  .tl-item{ grid-template-columns:1fr; gap:16px; }
}

/* ── Как я работаю ─────────────────────────── */
.how-head{
  margin-bottom: 52px;
}
.how-opener{
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
  gap: clamp(40px, 6vw, 80px);
  align-items: start;
  margin-bottom: clamp(72px, 9vw, 100px);
}
.how-epigraph{
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(26px, 3.6vw, 44px);
  line-height: 1.1;
  letter-spacing: -0.01em;
  color: var(--paper);
  margin: 0;
}
.how-epigraph em{ font-style: italic; color: var(--gold); }
.how-intro{ margin: 0; padding-top: 6px; }
.how-intro p{
  font-family: var(--serif);
  font-size: clamp(18px, 1.6vw, 22px);
  line-height: 1.62;
  color: var(--paper);
  margin: 0;
}
.how-offline{
  margin-top: 40px;
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(17px, 1.4vw, 20px);
  line-height: 1.5;
  color: var(--paper);
}
.cta-mark{
  margin-bottom: clamp(24px, 3.4vw, 34px);
}
.principles{
  border-top: 1px solid var(--rule-strong);
  padding-top: 48px;
}
.principles__header{
  margin-bottom: 48px;
}
.principles__grid{
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 56px;
}
.principle h3{
  font-family: var(--serif);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(22px, 2.5vw, 28px);
  line-height: 1.15;
  color: var(--gold);
  margin: 0 0 18px;
}
.principle p{
  font-family: var(--serif);
  font-size: 17px;
  line-height: 1.6;
  color: var(--paper-dim);
  margin: 0;
}

@media(max-width:980px){
  .principles__grid{ grid-template-columns:1fr; gap:40px; }
}

/* ── Вариант В — Эссе ──────────────────────── */
.vv-head{
  text-align: center;
  margin-bottom: 120px;
}
.vv-head__title{
  font-family: var(--serif);
  font-weight: 400;
  font-size: clamp(32px, 5vw, 56px);
  line-height: 1.05;
  letter-spacing: -.01em;
  margin: 0 auto;
  max-width: 22ch;
  color: var(--paper);
}
.vv-head__title em{ font-style:italic; color:var(--gold); }

.vv-essays{
  max-width: 62ch;
  margin: 0 auto;
  display: grid;
  gap: 80px;
}
.vv-item__head{
  display: flex;
  gap: 18px;
  align-items: baseline;
  margin-bottom: 20px;
}
.vv-dash{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .2em;
  color: var(--gold);
  flex-shrink: 0;
}
.vv-item h3{
  font-family: var(--serif);
  font-style: italic;
  font-weight: 400;
  font-size: clamp(24px, 3vw, 30px);
  line-height: 1.15;
  color: var(--paper);
  margin: 0;
}
.vv-item p{
  font-family: var(--serif);
  font-size: 20px;
  line-height: 1.6;
  color: var(--paper);
  margin: 0;
}
.vv-dim{ color: var(--paper-dim); }

/* ── Variant label shared ──────────────────── */
.section__mark-inline{
  font-family: var(--serif);
  font-style: italic;
  font-size: 20px;
  color: var(--gold);
  letter-spacing: 0;
  text-transform: none;
  display: block;
  margin-bottom: 10px;
}
.section__label{
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: var(--paper-mute);
}
.v-coda{
  font-family: var(--serif);
  font-style: italic;
  font-size: clamp(22px, 3vw, 30px);
  line-height: 1.25;
  color: var(--gold);
  text-align: center;
  margin: 80px auto 0;
  max-width: 30ch;
}
.v-coda--border{
  text-align: left;
  margin: 80px 0 0;
  padding-top: 40px;
  border-top: 1px solid var(--rule);
}

/* ── Format cards ────────────────────────────── */
.formats-grid{
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16px;
}
.format-card{
  min-height: 350px;
  display: flex;
  flex-direction: column;
  padding: 28px;
  border: 1px solid var(--rule);
  background: rgba(21, 18, 14, 0.72);
}
.format-card span{
  color: var(--gold);
  font-family: var(--mono);
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
}
.format-card h3{
  margin-top: 26px;
  color: var(--paper);
  font-family: var(--serif);
  font-size: clamp(1.5rem, 2.3vw, 2.15rem);
  font-weight: 500;
  line-height: 1.05;
}
.format-card p{
  margin-top: 20px;
  color: var(--paper-dim);
  line-height: 1.65;
}
.format-card small{
  display: block;
  margin-top: auto;
  padding-top: 26px;
  color: var(--paper-mute);
  font-family: var(--mono);
  font-size: 10px;
  letter-spacing: .12em;
  line-height: 1.55;
  text-transform: uppercase;
}

/* ── CTA (mid-page) ──────────────────────────── */
.cta-mid{
  text-align: center;
  padding: clamp(64px, 9vw, 104px) 0;
  border-top: 1px solid var(--rule);
  border-bottom: 1px solid var(--rule);
}
.cta-mid__text{
  font-family: var(--serif);
  font-size: clamp(22px, 3vw, 30px);
  line-height: 1.3;
  color: var(--paper);
  margin: 0 auto 32px;
  max-width: 26ch;
}
.cta-mid__text em{ font-style: italic; color: var(--gold); }

/* ── CTA section ─────────────────────────────── */
.cta-section{
  padding: clamp(92px, 13vw, 168px) 0 clamp(74px, 10vw, 118px);
  text-align: center;
}
.cta-eyebrow{
  display: flex;
  gap: 14px;
  align-items: center;
  justify-content: center;
  margin-bottom: clamp(24px, 3.4vw, 34px);
  color: var(--gold);
  font-family: var(--mono);
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .18em;
  text-transform: uppercase;
}
.cta-title{
  max-width: 840px;
  margin: 0 auto;
  font-family: var(--serif);
  font-size: clamp(2.4rem, 5.8vw, 5.4rem);
  font-weight: 400;
  line-height: 1;
