---
import ContactActions from "./ContactActions.astro";
import ResponsiveImage from "./ResponsiveImage.astro";
import { contacts, faq, formats, trust, values } from "@/content/site";
---

<main class="concept concept-quiet">
  <header class="quiet-header">
    <a href="/">Иван Тихов</a>
    <a href={contacts.telegram}>Telegram</a>
  </header>

  <section class="quiet-hero">
    <div class="quiet-letter">
      <p class="quiet-overline">Для предпринимателей и руководителей</p>
      <h1>Иногда нужен человек, с которым можно спокойно разобрать сложное</h1>
      <p>
        Без обещаний, без мотивационного шума и без попытки быстро “починить”
        то, что сначала нужно внимательно понять.
      </p>
      <ContactActions />
    </div>
    <ResponsiveImage
      name="portrait"
      alt="Иван Тихов"
      class="quiet-portrait"
      loading="eager"
      sizes="(min-width: 900px) 36vw, 100vw"
    />
  </section>

  <section class="quiet-note">
    <p>
      Я помогаю проходить кризисы и периоды неопределенности: находить смыслы,
      превращать хаос в порядок, а размышления — в решения и действия.
    </p>
  </section>

  <section class="quiet-situations">
    <h2>С чем приходят</h2>
    <div>
      <p>“Я все понимаю головой, но не могу принять решение”.</p>
      <p>“Команда растет, а ясности становится меньше”.</p>
      <p>“Нужно провести разговор, который давно откладывается”.</p>
      <p>“Я устал быть единственным человеком, который держит картину целиком”.</p>
    </div>
  </section>

  <section class="quiet-dialogue">
    <ResponsiveImage
      name="studio"
      alt="Иван Тихов в студии"
      class="quiet-studio"
      sizes="(min-width: 900px) 38vw, 100vw"
    />
    <div>
      <h2>Что происходит в работе</h2>
      <p>
        Мы не начинаем с методики. Сначала разбираем реальность: что произошло,
        что важно, где напряжение, где выбор, где уже есть ответ, но его трудно
        признать.
      </p>
      <p>
        Затем отделяем главное от шума и формулируем следующие действия так,
        чтобы их можно было действительно сделать.
      </p>
    </div>
  </section>

  <section class="quiet-formats">
    <h2>Можно работать по-разному</h2>
    <div>
      {formats.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="quiet-trust">
    <p>{trust.text}</p>
    <ul>
      {trust.items.map((item) => <li>{item}</li>)}
    </ul>
  </section>

  <section class="quiet-values">
    {values.map((item) => (
      <article>
        <h3>{item.title}</h3>
        <p>{item.text}</p>
      </article>
    ))}
  </section>

  <section class="quiet-faq">
    {faq.slice(0, 4).map((item) => (
      <details>
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </section>

  <section class="quiet-close">
    <p>Если есть запрос, который важно не тащить в одиночку, напишите мне.</p>
    <ContactActions tone="dark" />
  </section>
</main>
