---
import ContactActions from "./ContactActions.astro";
import ResponsiveImage from "./ResponsiveImage.astro";
import { boundaries, faq, formats, hero, situations, stats, trust, values } from "@/content/site";
---

<main class="design design-warm">
  <header class="warm-header">
    <a href="/" class="warm-brand">Иван Тихов</a>
    <nav aria-label="Навигация">
      <a href="#situations">Когда приходят</a>
      <a href="#formats">Форматы</a>
      <a href="#about">Опыт</a>
    </nav>
    <a href="https://t.me/tikhov" class="warm-header-link">Telegram</a>
  </header>

  <section class="warm-hero">
    <div class="warm-hero-copy">
      <p class="warm-role">{hero.role}</p>
      <h1>{hero.title}</h1>
      <p class="warm-lead">{hero.lead}</p>
      <p>{hero.text}</p>
      <ContactActions />
      <p class="warm-badge">{hero.badge}</p>
    </div>
    <figure class="warm-photo-wrap">
      <ResponsiveImage
        name="portrait"
        alt="Иван Тихов"
        class="warm-portrait"
        loading="eager"
        sizes="(min-width: 900px) 44vw, 100vw"
      />
    </figure>
  </section>

  <section class="warm-stats" aria-label="Опыт">
    {stats.map((item) => (
      <div>
        <strong>{item.value}</strong>
        <span>{item.label}</span>
      </div>
    ))}
  </section>

  <section class="warm-section" id="situations">
    <div class="warm-section-head">
      <p>Когда ко мне приходят</p>
      <h2>Когда нужно спокойно разложить сложное</h2>
    </div>
    <div class="warm-situations">
      {situations.map((item) => <p>{item}</p>)}
    </div>
  </section>

  <section class="warm-section warm-formats" id="formats">
    <div class="warm-section-head">
      <p>Форматы</p>
      <h2>Можно прийти на один разговор или работать регулярно</h2>
    </div>
    <div>
      {formats.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="warm-about" id="about">
    <ResponsiveImage
      name="studio"
      alt="Иван Тихов в студии"
      class="warm-about-photo"
      sizes="(min-width: 900px) 36vw, 100vw"
    />
    <div>
      <p class="warm-small">Почему можно доверять</p>
      <h2>{trust.title}</h2>
      <p>{trust.text}</p>
      <ul>
        {trust.items.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="warm-section">
    <div class="warm-section-head">
      <p>Как я работаю</p>
      <h2>Человечность, польза и честность</h2>
    </div>
    <div class="warm-values">
      {values.map((item) => (
        <article>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="warm-section warm-boundaries">
    <div class="warm-section-head">
      <p>Границы</p>
      <h2>С чем я не работаю</h2>
    </div>
    <div>
      {boundaries.map((item) => <p>{item}</p>)}
    </div>
  </section>

  <section class="warm-section warm-faq">
    <div class="warm-section-head">
      <p>FAQ</p>
      <h2>Перед первой встречей</h2>
    </div>
    <div>
      {faq.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="warm-contact">
    <h2>Если есть запрос, о котором важно подумать не в одиночку, напишите мне.</h2>
    <ContactActions tone="dark" />
  </section>
</main>
