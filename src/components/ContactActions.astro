---
import { contacts } from "@/content/site";

interface Props {
  tone?: "light" | "dark";
}

const { tone = "light" } = Astro.props;
---

<div class={`actions actions-${tone}`} aria-label="Контакты">
  <a class="action action-primary" href={contacts.telegram}>Обсудить запрос в Telegram</a>
  <a class="action action-secondary" href={contacts.email}>Написать на email</a>
</div>
