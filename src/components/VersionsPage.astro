---
const currentVersions = [
  {
    href: "/variant-a/",
    title: "A · Boardroom",
    label: "Премиальность и статус",
    text:
      "Черный boardroom-формат: закрытая управленческая работа, высокий чек, статус, трезвость и ощущение человека, которого зовут в сложные решения.",
    concept:
      "Подходит, если нужно транслировать силу, опыт CEO / CMO, уверенность и право быть внешним собеседником для собственников и топ-команд."
  },
  {
    href: "/variant-c/",
    title: "C · Magazine",
    label: "Теплота и бережность",
    text:
      "Журнальная версия личного бренда: больше воздуха, человеческого голоса, доверия и ощущения, что сложное можно спокойно разложить.",
    concept:
      "Подходит, если нужно показать не только статус, но и способ работы: внимательность, ясность, бережность к людям и реальности бизнеса."
  }
];
---

<main class="versions-page">
  <header class="versions-hero">
    <a href="/" class="versions-home">Иван Тихов</a>
    <p>Рабочая витрина версий</p>
    <h1>Два направления сайта</h1>
    <span>
      Оставляем два рабочих полюса и дальше усиливаем их: один про статус и
      премиальность, второй про личный голос, теплоту и бережную ясность.
    </span>
  </header>

  <section class="versions-section">
    <div class="versions-section-head">
      <p>Current</p>
      <h2>Выбери направление для просмотра</h2>
    </div>
    <div class="versions-grid">
      {currentVersions.map((version) => (
        <a class="version-card" href={version.href}>
          <span>{version.label}</span>
          <h3>{version.title}</h3>
          <p>{version.text}</p>
          <em>{version.concept}</em>
        </a>
      ))}
    </div>
  </section>
</main>
